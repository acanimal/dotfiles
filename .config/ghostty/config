app-notifications = false
desktop-notifications = false

# cursor-color = cell-foreground
cursor-style = block
cursor-style-blink = true

# font-family = "Symbols Nerd Font Mono"
font-size = 13

# This options is needed for writing spanish characters like ñ using the alt key
macos-option-as-alt = true

# Hide mouse while writing
mouse-hide-while-typing = true

split-divider-color = #66FF66
shell-integration-features = no-cursor

# This fix an issue with splitted windows separator
unfocused-split-fill = #BBBBBB

theme = "GitHub Dark Default"

# Rename tabs
keybind = cmd+r=prompt_surface_title
